{
  "name": "lm-code",
  "displayName": "LM-CODE",
  "description": "Expose one or more LM Studio servers as language models in GitHub Copilot Chat.",
  "version": "0.11.0",
  "publisher": "monsi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mr-tbot/LM-CODE.git"
  },
  "bugs": {
    "url": "https://github.com/mr-tbot/LM-CODE/issues"
  },
  "homepage": "https://github.com/mr-tbot/LM-CODE#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": ["AI", "Chat", "Other"],
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelChat:lmstudio"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "lmstudio",
        "displayName": "LM Studio"
      }
    ],
    "commands": [
      {
        "command": "lmstudioCopilot.openSettings",
        "title": "LM-CODE: Open Settings Panel",
        "category": "LM-CODE"
      },
      {
        "command": "lmstudioCopilot.refreshNow",
        "title": "LM-CODE: Refresh Models Now",
        "category": "LM-CODE"
      },
      {
        "command": "lmstudioCopilot.addServer",
        "title": "LM-CODE: Add Server",
        "category": "LM-CODE"
      },
      {
        "command": "lmstudioCopilot.exportConfig",
        "title": "LM-CODE: Export Configuration",
        "category": "LM-CODE"
      },
      {
        "command": "lmstudioCopilot.importConfig",
        "title": "LM-CODE: Import Configuration",
        "category": "LM-CODE"
      }
    ],
    "configuration": {
      "title": "LM-CODE",
      "properties": {
        "lmstudioCopilot.servers": {
          "type": "array",
          "default": [
            {
              "id": "default",
              "name": "Local LM Studio",
              "baseUrl": "http://localhost:1234",
              "apiKey": "",
              "enabled": true,
              "timeoutMs": 300000,
              "headers": {},
              "refreshIntervalSec": 0,
              "hiddenModels": []
            }
          ],
          "description": "List of LM Studio servers. Edit via the LM-CODE settings panel.",
          "items": {
            "type": "object",
            "required": ["id", "baseUrl"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "baseUrl": { "type": "string" },
              "apiKey": { "type": "string" },
              "enabled": { "type": "boolean" },
              "timeoutMs": { "type": "number" },
              "headers": { "type": "object" },
              "refreshIntervalSec": {
                "type": "number",
                "description": "Per-server override. 0 = use global."
              },
              "hiddenModels": {
                "type": "array",
                "items": { "type": "string" }
              },
              "showDuplicateModels": {
                "type": "boolean",
                "description": "Keep this server's copies of models visible even when another server already provides them."
              },
              "contextOverrides": {
                "type": "object",
                "additionalProperties": { "type": "number" },
                "description": "Per-model advertised context window override (model id -> tokens). Use when a model is loaded with a larger context than its metadata reports, e.g. after `lms load <model> -c 1048576`."
              }
            }
          }
        },
        "lmstudioCopilot.dedupeAcrossServers": {
          "type": "boolean",
          "default": true,
          "description": "Show each model only once when several servers list it (common with LM Link, where every machine reports the whole network's models). The first enabled server that lists a model provides it; other copies are hidden unless that server sets showDuplicateModels."
        },
        "lmstudioCopilot.refreshIntervalSec": {
          "type": "number",
          "default": 60,
          "minimum": 0,
          "description": "Global refresh interval in seconds for polling LM Studio /v1/models. 0 disables auto-refresh."
        },
        "lmstudioCopilot.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar item with the number of available models."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lmstudioCopilot",
          "title": "LM-CODE",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "lmstudioCopilot": [
        {
          "id": "lmstudioCopilot.servers",
          "name": "Servers & Models"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "lmstudioCopilot.openSettings",
          "when": "view == lmstudioCopilot.servers",
          "group": "navigation"
        },
        {
          "command": "lmstudioCopilot.refreshNow",
          "when": "view == lmstudioCopilot.servers",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
